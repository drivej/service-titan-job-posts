{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "st-sync/recent-jobs",
  "title": "Recent Local Jobs",
  "category": "widgets",
  "icon": "location-alt",
  "description": "Shows recently approved jobs for a service and city.",
  "usesContext": ["postId", "postType"],
  "attributes": {
    "serviceSlug": {
      "type": "string",
      "default": ""
    },
    "locationSlug": {
      "type": "string",
      "default": ""
    },
    "jobsToShow": {
      "type": "number"
    },
    "heading": {
      "type": "string",
      "default": ""
    },
    "intro": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "anchor": true,
    "html": false
  },
  "textdomain": "service-titan-job-post",
  "editorScript": "file:./index.js",
  "style": "file:./style.css"
}
