DEV_MODE=false

# Production claim mode. The hosted service returns only active/trialing sites.
SERVICE_URL=
WORKER_API_KEY=
ST_APP_KEY=

# One-site development delivery target. Production receives these values from
# SERVICE_URL /internal/v1/sync/claims instead.
STANDALONE_SYNC=false
WP_URL=
SITE_ID=
SITE_SIGNING_SECRET=

# ServiceTitan connection. In production these values belong in encrypted
# hosted-service storage, not in a customer-controlled WordPress database.
ST_ENVIRONMENT=production
ST_TENANT_ID=
ST_CLIENT_ID=
ST_CLIENT_SECRET=

# Per-tenant content policy.
ST_JOBS_SINCE=
ST_MIN_PRICE=0
ST_MIN_SUMMARY_WORDS=5
ST_COMPLETION_CUSTOM_FIELD=
ST_DEFAULT_SERVICE_SLUG=
ST_SERVICE_MAPPINGS=
ST_ALLOWED_CITIES=
ST_EXCLUDED_JOB_TYPES=
